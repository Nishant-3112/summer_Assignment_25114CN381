#include <stdio.h>

int main(){
    int n,ld ,rev=0;
    printf("Enter Number =>");
    scanf("%d",&n);
    int temp=n;
    while(n!=0){
      ld=n%10;
      rev=rev*10+ld;
      n=n/10; 
    }
    if(temp==rev){
        printf("The Given number is Palindrome");
    }
    else{
        printf("The Given number is not Palindrome");
    }
    return 0;
}
